{
  "name": "@effect-x/fx",
  "version": "0.0.1",
  "description": "Shared config, RPC, and worker runtime helpers for Effect applications.",
  "keywords": [
    "effect",
    "effect-x",
    "rpc",
    "workers",
    "browser",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/pkgs#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/pkgs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/pkgs.git",
    "directory": "packages/fx"
  },
  "type": "module",
  "sideEffects": [],
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./*": "./src/*.ts",
    "./*/*": "./src/*/*.ts",
    "./*/*/*": "./src/*/*/*.ts",
    "./internal/*": null,
    "./*/index": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      "./*": "./dist/*.js",
      "./*/*": "./dist/*/*.js",
      "./*/*/*": "./dist/*/*/*.js",
      "./internal/*": null,
      "./*/index": null
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -b tsconfig.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.63.0",
    "@effect-x/otel": "workspace:^",
    "@effect-x/react-router": "workspace:^",
    "@effect/platform": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@effect/rpc": "catalog:",
    "effect": "catalog:",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  }
}
