{
  "name": "@effect-x/i18n",
  "version": "0.0.1",
  "description": "i18next helpers and Effect services for React applications.",
  "keywords": [
    "effect",
    "effect-x",
    "i18n",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/pkgs#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/pkgs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/pkgs.git",
    "directory": "packages/i18n"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    "./package.json": "./package.json",
    "./*": "./src/*.ts",
    "./server-wrapper": "./src/server-wrapper.tsx",
    "./internal/*": null,
    "./*/index": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      "./*": "./dist/*.js",
      "./server-wrapper": "./dist/server-wrapper.js",
      "./internal/*": null,
      "./*/index": null
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -b tsconfig.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "accept-language-parser": "^1.5.0",
    "effect": "catalog:",
    "i18next": "catalog:",
    "intl-parse-accept-language": "^1.0.0",
    "react-i18next": "^17.0.2"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@vitest/browser-playwright": "4.1.5",
    "react": "19.2.5",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "effect": "^3.21.0",
    "i18next": "^26.0.4",
    "react": "^19.2.4",
    "react-i18next": "^17.0.2"
  },
  "tags": [
    "typescript",
    "i18n",
    "react"
  ]
}
