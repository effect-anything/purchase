{
  "$schema": "https://www.unpkg.com/wrangler/config-schema.json",
  "name": "workflow-timer-worker",
  "main": "index.ts",
  "compatibility_date": "2026-03-28",
  "compatibility_flags": ["nodejs_compat", "enable_request_signal"],
  "kv_namespaces": [
    {
      "binding": "RESULT_KV",
      "id": "workflow-timer-results"
    }
  ],
  "workflows": [
    {
      "binding": "TIMER_WORKFLOW",
      "name": "timer-workflow",
      "class_name": "TimerWorkflow"
    }
  ]
}
