{
  "name": "@effect-x/db",
  "version": "0.1.0",
  "description": "Schema-bound database helpers for Effect.",
  "keywords": [
    "effect",
    "effect-x",
    "database",
    "kysely",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/pkgs#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/pkgs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/pkgs.git",
    "directory": "packages/db"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./*/index": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./*/index": null
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -b tsconfig.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect-x/sql-kysely": "workspace:^",
    "@effect/cli": "catalog:",
    "@effect/experimental": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/sql": "catalog:",
    "@prisma/config": "^7.4.1",
    "@prisma/generator-helper": "^7.4.1",
    "@prisma/internals": "^7.4.1",
    "effect": "catalog:",
    "kysely": "0.28.16",
    "nanoid": "^5.1.7",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@effect/platform-node": "catalog:",
    "@effect/sql-sqlite-node": "^0.52.0",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "^3.21.0"
  },
  "tags": [
    "typescript",
    "database",
    "effect"
  ]
}
