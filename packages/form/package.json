{
  "name": "@effect-x/form",
  "version": "0.0.1",
  "description": "Effect Schema integrations for react-hook-form.",
  "keywords": [
    "effect",
    "effect-x",
    "forms",
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/pkgs#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/pkgs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/pkgs.git",
    "directory": "packages/form"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./resolver/*": "./src/resolver/*.ts",
    "./internal/*": null,
    "./*/index": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./resolver/*": "./dist/resolver/*.js",
      "./internal/*": null,
      "./*/index": null
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -b tsconfig.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect-x/atom-react": "workspace:^",
    "@effect-x/db": "workspace:^",
    "@standard-schema/spec": "^1.1.0",
    "@standard-schema/utils": "^0.3.0",
    "effect": "catalog:",
    "react-hook-form": "^7.72.1"
  },
  "devDependencies": {
    "@effect/sql": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@vitest/browser-playwright": "4.1.5",
    "react": "19.2.5",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "effect": "^3.21.0",
    "react": "^19.2.4",
    "react-hook-form": "^7.72.1"
  },
  "tags": [
    "typescript",
    "forms",
    "react"
  ]
}
