{
  "name": "@effect-x/db-cli",
  "version": "0.1.0",
  "description": "Schema-bound database helpers for Effect.",
  "keywords": [
    "effect",
    "effect-x",
    "database",
    "kysely",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/pkgs#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/pkgs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/pkgs.git",
    "directory": "packages/db"
  },
  "files": [
    "dist/bin.js",
    "dist/vendor/**/*"
  ],
  "bin": {
    "db": "./dist/bin.js"
  },
  "type": "module",
  "sideEffects": [],
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json"
    },
    "provenance": true
  },
  "scripts": {
    "build": "bun run ./scripts/clean-build.ts && tsgo -b tsconfig.json && pnpm babel && bun run ./scripts/build.ts && bun run ./scripts/vendor-prisma.ts && bun run ./scripts/build.ts --prune",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "optionalDependencies": {
    "wrangler": "^4.85.0"
  },
  "devDependencies": {
    "@effect-x/db": "workspace:^",
    "@effect/platform-node": "4.0.0-beta.57",
    "@effect/sql": "catalog:",
    "@effect/sql-sqlite-node": "4.0.0-beta.57",
    "@effect/vitest": "catalog:",
    "@prisma/config": "^7.4.1",
    "@prisma/generator-helper": "^7.4.1",
    "@prisma/internals": "^7.4.1",
    "@sindresorhus/slugify": "^3.0.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "^1.3.13",
    "@types/node": "catalog:",
    "confbox": "^0.2.4",
    "effect": "4.0.0-beta.57",
    "kysely": "^0.28.16",
    "nanoid": "^5.1.7",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "uuid": "^14.0.0",
    "vitest": "catalog:"
  },
  "tags": [
    "typescript",
    "database",
    "effect"
  ]
}
