{
  "name": "@effect-x/otel",
  "version": "0.0.1",
  "description": "OpenTelemetry helpers for Effect applications.",
  "keywords": [
    "effect",
    "effect-x",
    "opentelemetry",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/pkgs#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/pkgs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/pkgs.git",
    "directory": "packages/otel"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    "./package.json": "./package.json",
    "./*": "./src/*.ts",
    "./session/*": "./src/session/*.ts",
    "./internal/*": null,
    "./*/index": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      "./*": "./dist/*.js",
      "./session/*": "./dist/session/*.js",
      "./internal/*": null,
      "./*/index": null
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -b tsconfig.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect/opentelemetry": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-browser": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "^3.21.0"
  },
  "tags": [
    "typescript",
    "opentelemetry",
    "effect"
  ]
}
