{
  "name": "@effect-x/purchase",
  "version": "0.0.1",
  "description": "Provider-neutral payment SDK for Effect applications with subscriptions, one-time purchases, and credits workflows.",
  "keywords": [
    "payments",
    "billing",
    "stripe",
    "paddle",
    "subscription",
    "credits",
    "effect",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/purchase#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/purchase/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/purchase.git",
    "directory": "packages/purchase"
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/public.ts",
    "./db": "./src/db.ts",
    "./config": "./src/config.ts",
    "./dsl": "./src/dsl.ts",
    "./errors": "./src/errors.ts",
    "./provider": "./src/provider.ts",
    "./schema": "./src/schema.ts",
    "./sdk": "./src/sdk.ts",
    "./harness": "./src/harness.ts",
    "./paddle": "./src/paddle.ts",
    "./stripe": "./src/stripe.ts",
    "./tables": "./src/tables.ts",
    "./internal/*": null,
    "./*/index": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/public.js",
      "./db": "./dist/db.js",
      "./config": "./dist/config.js",
      "./dsl": "./dist/dsl.js",
      "./errors": "./dist/errors.js",
      "./provider": "./dist/provider.js",
      "./schema": "./dist/schema.js",
      "./sdk": "./dist/sdk.js",
      "./harness": "./dist/harness.js",
      "./paddle": "./dist/paddle.js",
      "./stripe": "./dist/stripe.js",
      "./tables": "./dist/tables.js",
      "./internal/*": null,
      "./*/index": null
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -b tsconfig.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest",
    "test:unit": "vitest run --project @effect-x/purchase-unit",
    "test:e2e": "vitest run --project @effect-x/purchase-e2e",
    "test:provider:stripe": "PROVIDER=stripe vitest run --project @effect-x/purchase-unit",
    "test:provider:paddle": "PROVIDER=paddle vitest run --project @effect-x/purchase-unit",
    "test:core": "vitest run test/core",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect-x/db": "0.0.1",
    "@effect/experimental": "catalog:",
    "@effect/sql": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/cli": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-pg": "catalog:",
    "@effect/vitest": "catalog:",
    "@paddle/paddle-node-sdk": "^3.7.0",
    "effect-playwright": "^0.4.2",
    "playwright-core": "^1.60.0",
    "vitest": "catalog:",
    "stripe": "^22.0.1"
  },
  "optionalDependencies": {
    "effect-playwright": "^0.4.2",
    "playwright-core": "^1.60.0"
  },
  "tags": [
    "typescript",
    "effect"
  ]
}
