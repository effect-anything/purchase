{
  "name": "@effect-x/errors",
  "version": "0.0.1",
  "description": "Error encoding, decoding, recovery, and HTTP error helpers for Effect applications.",
  "keywords": [
    "effect",
    "effect-x",
    "errors",
    "http",
    "react-router",
    "typescript"
  ],
  "homepage": "https://github.com/effect-anything/pkgs#readme",
  "bugs": {
    "url": "https://github.com/effect-anything/pkgs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effect-anything/pkgs.git",
    "directory": "packages/errors"
  },
  "files": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "type": "module",
  "sideEffects": [],
  "exports": {
    "./package.json": "./package.json",
    "./*": "./src/*.ts",
    "./internal/*": null,
    "./*/index": null
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./package.json": "./package.json",
      "./*": "./dist/*.js",
      "./internal/*": null,
      "./*/index": null
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -b tsconfig.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "check": "tsgo -b tsconfig.json",
    "test": "vitest"
  },
  "dependencies": {
    "@effect/platform": "catalog:",
    "@effect/sql": "catalog:",
    "effect": "catalog:",
    "react": "^19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  }
}
